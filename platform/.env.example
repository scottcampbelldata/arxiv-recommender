# Postgres (arxiv-recommender uses its own DB + role on the local cluster)
PGHOST=localhost
PGPORT=5432
PGDATABASE=arxiv_recs
PGUSER=arxrec_app
PGPASSWORD=replace-me

# OpenAlex politely asks for a contact email in the User-Agent of every request,
# which puts you in the polite pool with higher rate limits (10 req/sec).
OPENALEX_MAILTO=scottcampbell8@icloud.com

# Random seed for deterministic eval / training
RANDOM_SEED=20260625

# FastAPI server
ARXREC_API_HOST=127.0.0.1
ARXREC_API_PORT=8820
ARXREC_LOG_LEVEL=INFO

# Comma-separated list of origins allowed to call the API.
# Dev: http://localhost:3000
# Prod: https://papers.scottcampbell.io
ARXREC_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Top-k default
ARXREC_DEFAULT_K=10
